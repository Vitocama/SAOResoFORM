<Window x:Class="SAOResoForm.ModificaControl.ModificaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modifica Personale"
        Width="1050"
        Height="750"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <DockPanel Margin="20" Style="{StaticResource TotaleSfondoDock}" >

        <!-- ========================= -->
        <!-- TITOLO -->
        <!-- ========================= -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="MODIFICA DATI PERSONALE"
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                        Style="{StaticResource WhiteBoldText}"
                       />
            <Separator Margin="200,6"/>
        </StackPanel>

        <!-- ========================= -->
        <!-- TOGGLE REPARTO/SEZIONE/NUCLEO -->
        <!-- ========================= -->
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,16">
            <TextBlock Text="🔃 Mostra modifica Reparto / Sezione / Nucleo"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       Style="{StaticResource WhiteBoldText}"
                       FontSize="20"
                       />
            <CheckBox IsChecked="{Binding ModificaRepartoSezioneNucleo}"
                      VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ========================= -->
        <!-- FOOTER: PULSANTE AGGIORNA -->
        <!-- ========================= -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="LightGray"
                BorderThickness="0,1,0,0"
                Padding="0,12,0,0"
                Margin="0,12,0,0">
            <Button Content="✏  AGGIORNA DATI"
                    Command="{Binding UpdateCommand}"
                    HorizontalAlignment="Center"
                    Padding="30,8"
                    FontSize="13"
                    FontWeight="SemiBold"/>
        </Border>

        <!-- ========================= -->
        <!-- COLONNE PRINCIPALI -->
        <!-- ========================= -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="1.6*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== COL 0: ANAGRAFICA ===== -->
            <StackPanel Grid.Column="0">

                <!-- Reparto — visibile solo se toggle attivo -->
                <StackPanel Visibility="{Binding ModificaRepartoSezioneNucleo, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,0,12">
                    <TextBlock Text="REPARTO"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"
                                Style="{StaticResource WhiteBoldText}"/>
                    <ListBox ItemsSource="{Binding Reparti}"
                             SelectedItem="{Binding RepartoSelezionato}"
                             Height="180"
                             Style="{DynamicResource ListBox1}"
                             />
                </StackPanel>

                <TextBlock Text="NOME"
                           FontWeight="SemiBold"
                           Margin="0,0,0,3"
                            Style="{StaticResource WhiteBoldText}"/>
                <TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}"
                         Padding="6,4"
                         Height="32"
                         Margin="0,0,0,10"/>

                <TextBlock Text="COGNOME"
                           FontWeight="SemiBold"
                           Margin="0,0,0,3"
                            Style="{StaticResource WhiteBoldText}"
                           />
                <TextBox Text="{Binding Cognome, UpdateSourceTrigger=PropertyChanged}"
                         Padding="6,4"
                         Height="32"
                         Margin="0,0,0,10"/>

                <TextBlock Text="MATRICOLA"
                           FontWeight="SemiBold"
                           Margin="0,0,0,3"
                            Style="{StaticResource WhiteBoldText}"
                           />
                <TextBox Text="{Binding Matricola}"
                         IsReadOnly="True"
                         Padding="6,4"
                         Height="32"
                         Foreground="Gray"/>

            </StackPanel>

            <!-- Separatore verticale -->
            <Separator Grid.Column="1"
                       Width="1"
                       HorizontalAlignment="Center"/>

            <!-- ===== COL 2: DATI PROFESSIONALI ===== -->
            <StackPanel Grid.Column="2">

                <!-- Sezione — visibile solo se toggle attivo -->
                <StackPanel Visibility="{Binding ModificaRepartoSezioneNucleo, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,0,12">
                    <TextBlock Text="SEZIONE"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"
                                Style="{StaticResource WhiteBoldText}"
                               />
                    <ListBox ItemsSource="{Binding Sezioni}"
                             SelectedItem="{Binding SezioneSelezionata}"
                             Height="180"
                              Style="{DynamicResource ListBox2}"
                             />
                </StackPanel>

                <TextBlock Text="INCARICO"
                           FontWeight="SemiBold"
                           Margin="0,0,0,3"
                            Style="{StaticResource WhiteBoldText}"
                           />
                <ComboBox ItemsSource="{Binding Incarichi}"
                          SelectedItem="{Binding IncaricoSelezionato}"
                          Padding="6,4"
                          Height="32"
                          Margin="0,0,0,10"/>

                <TextBlock Text="STATO DI SERVIZIO"
                           FontWeight="SemiBold"
                           Margin="0,0,0,3"
                            Style="{StaticResource WhiteBoldText}"
                           />
                <ComboBox ItemsSource="{Binding Servizio}"
                          SelectedItem="{Binding ServizioSelezionato}"
                          Padding="6,4"
                          Height="32"
                          Margin="0,0,0,10"/>

                <TextBlock Text="ANNOTAZIONI"
                           FontWeight="SemiBold"
                           Margin="0,0,0,3"
                            Style="{StaticResource WhiteBoldText}"
                           />
                <TextBox Text="{Binding Annotazioni, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         Height="100"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Padding="6,4"/>

            </StackPanel>

            <!-- Separatore verticale -->
            <Separator Grid.Column="3"
                       Width="1"
                       HorizontalAlignment="Center"/>

            <!-- ===== COL 4: CLASSIFICAZIONE ===== -->
            <StackPanel Grid.Column="4">

                <!-- Nucleo — visibile solo se toggle attivo -->
                <StackPanel Visibility="{Binding ModificaRepartoSezioneNucleo, Converter={StaticResource BoolToVis}}"
                            Margin="0,0,0,12">
                    <TextBlock Text="NUCLEO"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"
                                Style="{StaticResource WhiteBoldText}"
                               />
                    <ListBox ItemsSource="{Binding Nuclei}"
                             SelectedItem="{Binding NucleoSelezionato}"
                             Height="180"
                              Style="{DynamicResource ListBox3}"
                             />
                </StackPanel>

                <TextBlock Text="MIL / CIV"
                           FontWeight="SemiBold"
                           Margin="0,0,0,3"
                            Style="{StaticResource WhiteBoldText}"
                           />
                <ComboBox ItemsSource="{Binding Militari}"
                          SelectedItem="{Binding MilitariSelezionato}"
                          Padding="6,4"
                          Height="32"
                          Margin="0,0,0,10"/>

                <TextBlock Text="RUOLO / CATEGORIA"
                           FontWeight="SemiBold"
                           Margin="0,0,0,3"
                            Style="{StaticResource WhiteBoldText}"
                           />
                <TextBox Text="{Binding CategoriaProfilo, UpdateSourceTrigger=PropertyChanged}"
                         Padding="6,4"
                         Height="32"
                         Margin="0,0,0,10"/>

                <TextBlock Text="GRADO / QUALIFICA"
                           FontWeight="SemiBold"
                           Margin="0,0,0,3"
                            Style="{StaticResource WhiteBoldText}"
                           />
                <TextBox Text="{Binding GradoQualifica, UpdateSourceTrigger=PropertyChanged}"
                         Padding="6,4"
                         Height="32"
                         Margin="0,0,0,10"/>

            </StackPanel>
        </Grid>
    </DockPanel>
</Window>