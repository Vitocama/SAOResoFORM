<Window x:Class="SAOResoForm.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Accesso riservato"
        Width="350" Height="190"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow">

    <StackPanel Margin="20">
        <TextBlock Text="Inserisci la password per accedere:"
                   FontSize="13" Margin="0,0,0,10"/>

        <PasswordBox x:Name="TxtPassword"
                     FontSize="13" Margin="0,0,0,8"
                     KeyDown="TxtPassword_KeyDown"/>

        <TextBlock x:Name="TxtErrore"
                   Text="Password errata."
                   Foreground="Red"
                   Visibility="Collapsed"
                   Margin="0,0,0,10"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annulla" Width="80" Margin="0,0,10,0"
                    Click="BtnAnnulla_Click"/>
            <Button Content="Accedi" Width="80"
                    Click="BtnAccedi_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
